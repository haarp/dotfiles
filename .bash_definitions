# Curl host override
function curll() {
	if [[ $# -lt 2 || "$1" == -* || "$1" =~ "/" || "$2" == -* ]]; then
		echo "Usage: $FUNCNAME <newhost> <URL> [curl args]" >&2
		return 1
	fi

	local url="$2"
	local oldhost="${url/http?(s):\/\//}"; oldhost="${oldhost%%/*}"
	local newhost="$1"
	shift 2

	local args=""; local port
	for port in 80 443 25 465; do
		args+="--connect-to $oldhost:$port:$newhost:$port "
	done

	curl $args "$url" "$@"
}

