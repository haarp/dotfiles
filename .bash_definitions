function us_proxy() {
	local agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:77.0) Gecko/20100101 Firefox/77.0"
	local blacklist=(38.77.36.35:8080)

	echo "Finding US proxy..." >&2
