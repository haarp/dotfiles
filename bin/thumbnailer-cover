#!/bin/bash
# cover art thumbnailer for audio files

INPUT="$1"
OUTPUT="$2"
SIZE="$3"
URL="$4"

ffmpeg -i "$INPUT" -an -vf scale="'if(gt(iw\,ih),$SIZE,-1)':'if(gt(iw\,ih),-1,$SIZE)'" -y "$OUTPUT" &>/dev/null

[[ -s "$OUTPUT" ]] || {
	gdbus call --session --dest=org.freedesktop.thumbnails.Cache1 --object-path /org/freedesktop/thumbnails/Cache1 \
		--method org.freedesktop.thumbnails.Cache1.Delete "['$URL']" >/dev/null
	exit 1
}
