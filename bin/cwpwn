#!/bin/bash

## Protocol info
# Query:
# < fefd 09 d9e7cf7b (request challenge				3rd chunk: timestamp
# > 09 d9e7cf7b 31313631393133343632 00 (challenge)		3rd chunk: challenge separated by 3's -> 1161913462
# < fefd 00 27e8cf7b 45416476 ffffff01 (request server info)	3rd chunk: timestamp, 4th chunk: challenge response (1161913462 = 0x45416476)
#								5th chunk: ffffff=serverinfo,rules,players -> yes,yes,yes
# > data
#
# http://wiki.unrealadmin.org/UT3_query_protocol

# Connect (Example):
# < 


payload="\x3c\x00\x00\x1a\x49\x00\x00\x00\x01\x00\x00\x00\x01\x00\x00\x00\x01\x00\x00\x00\x06\x00\x00\x00\x03\x14\x8e\x60\x64\x37\x36\x37\x31\x36\x31\x36\x64\x36\x32\x36\x65\x37\x34\x37\x30\x36\x66\x36\x64\x37\x30\x37\x36\x36\x39\x37\x30\x36\x66\x36\x61\x37\x39\x37\x39\x36\x39\x37\x61\x33\x31\x33\x33\x33\x34\x33\x38\x33\x35\x33\x30\x33\x34\x33\x34\x33\x33\x33\x37\x32\x31\x33\x31\x32\x65\x33\x31\x32\x65\x33\x36\x33\x37\x33\x32\x33\x39\x33\x61\x34\x62\x32\x33\x33\x34\x36\x34\x33\x35\x33\x37\x33\x34\x36\x33\x33\x34\x36\x33\x33\x33\x33\x30\x33\x32\x36\x35\x33\x33\x33\x36\x33\x32\x36\x35\x33\x33\x33\x31\x33\x61\x33\x34\x33\x38\x33\x34\x33\x31\x33\x34\x33\x31\x33\x35\x33\x32\x33\x35\x33\x30\x33\x61"

[[ $# == 2 ]] || { echo "Usage: ${0##*/} HOST PORT"; exit 1; }

##ip=$(dig +short $1)
ip="$1"
[[ $ip ]] || { echo "hostname lookup failed!"; exit 2; }

trap 'kill $(jobs -p) &>/dev/null' EXIT
echo "prints . for attempt, ! for response, ctrl+c to exit"

while true; do
	if [[ $(jobs -p | wc -l) -lt 150 ]]; then
		echo -n "."
		[[ $(echo -e "$payload" | nc -u -w1 $ip $2) ]] && echo -n "!" &
	else
		sleep 0.1
	fi
done

echo ""
