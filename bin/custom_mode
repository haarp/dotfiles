#!/bin/sh
# Add a custom xrandr mode to an output and print its name
# keep compatible with `sh`

[ $# -eq 4 ] || {
	echo "Usage: $(basename "$0") <output> <x> <y> <refresh>" >&2
	exit 127
}
command -v cvt12 >/dev/null || {
	# `cvt` doesn't support reduced blanking v2
	echo "cvt12 not installed! Falling back to cvt and reduced blanking v1" >&2
	oldcvt=1
}

# generate modeline (always with best "Reduced Blanking" available)
# theoretically, more customization is possible with e.g. https://tomverbeure.github.io/video_timings_calculator
# however, X will not see the proper refresh rate for those...
if [ "$oldcvt" ]; then
	modeline=$(cvt -r $2 $3 $4)
else
	modeline=$(cvt12 $2 $3 $4 --rb-v2)
fi
modeline=$(echo "$modeline" | sed -e '1d' -e 's/Modeline //' -e 's/"//g')
modename=$(echo "$modeline" | awk '{print $1}')

[ "$modeline" ] || exit 1

# create mode in mode pool if it doesn't already exist
xrandr --current | grep -q "$modename" || {
	xrandr --newmode $modeline || exit 2
}

# add mode to output
xrandr --addmode "$1" "$modename" || exit 3

echo "$modename"

# switch to mode
# `if` to avoid polluting exit code
if [ $SWITCH ]; then
	xrandr --output "$1" --mode "$modename"
fi
