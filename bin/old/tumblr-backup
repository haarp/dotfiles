#!/bin/bash

# TODO: Retrieve full list of notes on each post

if [[ ! $1 ]]; then
	echo "Please supply your blog name! e.g. 'spacedicks' for spacedicks.tumblr.com"
	echo "Backs up to current dir. Probably won't backup audio or video content!"
	exit 1
fi

# main fetch
wget -nv -r -l 3 -k -p -e robots=off -U Mozilla/5.0 -N \
-H -D "media.tumblr.com,*.media.tumblr.com,$1.tumblr.com" \
-X "page,archive,tagged" -R "archive*,ask*,index*,mobile*,random*,rss*,submit*" \
http://"$1".tumblr.com/archive/{2010..2015}/{1..12}

# fetch archive.css
wget http://assets.tumblr.com/stylesheets/compressed/archive.css -O "$1".tumblr.com/archive/archive.css || {
	echo "Failed to fetch archive.css, archive display might be broken!"
	exit 2
}
# fix archives to use local archive.css
sed -i -e 's:http\://assets.tumblr.com/stylesheets/compressed/archive.css:../archive.css:' "$1".tumblr.com/archive/*/*
