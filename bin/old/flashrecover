#!/bin/bash
# Recover files of flash movies (does not work with Youtube DASH playback)
# Copy with cp -L

recover() {
	#get process id
	pid=$(echo $lsofline | awk '{print $2}')

	#get deleted filename
	filename=$(echo $lsofline | awk '{print $10}')

	#exclude .db files
	[[ "$filename" == *.db ]] && return

	#search file descriptors of process for filename
	fd=$(ls -l /proc/$pid/fd/ | grep "\-> $filename (deleted)" | awk '{print $9}')

	#echo video to stdout, original filenamename to stderr
	echo -n "/proc/$pid/fd/$fd"
	echo -n " (org. $filename)" >&2
	echo ""
}

#read lsof output for deleted flash filenames, then run recover() for each
lsof +L1 | grep "/tmp/FlashXX...... (deleted)" | while read lsofline; do recover; done
