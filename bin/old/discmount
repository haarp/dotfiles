#!/bin/bash

# CD image mounter for CDemu 1.2.0
# v0.4 by haarp
# TODO: Make it possible to parse more than one file at once ($2, $3, etc.)
# TODO: Automatically open newly-mounted disk

# function to have zenity behave like echo
echozenity() {
	zenity --error --no-wrap --text="$1"
}

# If we're running on from a file browser use zenity, otherwise echo
if [ $TERM = linux ]; then
	echo="echozenity"
else
	echo="echo"
fi

# Make sure the daemon is running
if ! pgrep cdemud >/dev/null 2>/dev/null; then
	$echo "CDemu daemon is not running, aborting."
	exit 1
fi

# Make sure we have a free device and save lowest free dev in $DEV
DEV=$(cdemu status | grep "N/A" | head -n1 | awk '{print $1}')
if [ ! "$DEV" ]; then
	$echo "You can not load any more images."
	exit 1
fi

# Get filename extension
EXT="${1##*.}"

# See if supported extensions contain actual extension, else die
grep -q -i "PARSER-$EXT:" <(cdemu enum-supported-parsers) || $echo "Selected file is not a supported image." || exit 1

# Execute CDemu, load image into $DEV and save output in $CDEMU
# err_msg if CDemu complained about anything (exit code != 0)
if ! CDEMU=$(cdemu load $DEV "$1"); then
	$echo "$CDEMU"; exit 1
fi

exit 0
