#!/usr/bin/env bash
# adapted from https://github.com/alexzorin/i3-lastpass

USER="mo@secomba.com"
TIMEOUT=$(( 3600 * 24 * 14 ))

set -e

if [[ $(lpass status --color=never) == "Not logged in." ]]; then
	LPASS_AGENT_TIMEOUT=$TIMEOUT lpass login --trust $USER
fi



## try fetching without syncing, but enable syncing if that fails
#until items=$(lpass ls --color=never --sync=${sync:-no} --format="%aN (%au) (%al) | %ai"); do
#	if [[ "$sync" == "auto" ]]; then	# abort condition
#		notify-send -i lastpass LastPass "Something went wrong!\n$items"
#		exit 1
#	fi
#	sync="auto"
#done
## FIXME: will never sync, so do it always. still faster than the shitty web thingie
items=$(lpass ls --color=never --sync=auto --format="%aN (%au) (%al) | %ai")

selection=$(<<< "$items" dmenu -p "LastPass" -i -l 5 -z 1200 -x 350 -y 300)
selection_id=${selection##* | }

## use pbcopy on OSX
lpass show --sync=no --password "$selection_id" | xclip -i -rmlastnl -selection primary

if [[ ${PIPESTATUS[0]} -eq 0 ]]; then
	notify-send -i lastpass LastPass "Password copied to Primary Selection"
else
	notify-send -i lastpass LastPass "Couldn't get that entry!"
	exit 1
fi
