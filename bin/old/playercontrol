#!/bin/bash
# https://github.com/mpv-player/mpv/blob/master/DOCS/man/ipc.rst
# https://mpv.io/manual/stable/#property-list
# https://gist.github.com/dwgill/a66769e0edef69c04d3b
# https://github.com/jcmuller/pianobar-scripts
# needs xfce-pulseaudio-plugin's "Control Playback of Media Players" to be disabled for xfsettings to bind the keys

# set in mpv config: input-ipc-server=/home/foo/.config/mpv/socket
MPV_SOCKET="$HOME/.config/mpv/socket"
PIANOBAR_FIFO="$HOME/.config/pianobar/ctl"


get_title() {
	local result=$(<<< '{ "command": ["get_property", "media-title"] }' socat - "$MPV_SOCKET" 2>&1)
	if [[ "$result" =~ '"error":"success"' ]]; then
		local string="${result#\{\"data\":\"}"
		string="${string%\",\"error\":\"success\"\}}"

		echo "$string"
		return 0
	else
		return 1
	fi
}

format_time() {
	local h=$(($1/3600))
	local m=$((($1%3600)/60))
	local s=$(($1%60))
	[[ "${#m}" -eq 1 ]] && m="0$m"
	[[ "${#s}" -eq 1 ]] && s="0$s"

	if ((h>0)); then
		echo "${h}:${m}:${s}"
	else
		echo "${m}:${s}"
	fi
}
get_timestring() {
	local result=$(<<< '{ "command": ["get_property", "time-pos"] }' socat - "$MPV_SOCKET" 2>&1)
	if [[ "$result" =~ '"error":"success"' ]]; then
		local string="${result#\{\"data\":}";
		string="${string%,\"error\":\"success\"\}}"
		string="${string%.*}"	# strip decimal places

		local timestring="$(format_time $string)"
	else
		return 1
	fi

	local result=$(<<< '{ "command": ["get_property", "playtime-remaining"] }' socat - "$MPV_SOCKET" 2>&1)
	if [[ "$result" =~ '"error":"success"' ]]; then
		local string="${result#\{\"data\":}"
		string="${string%,\"error\":\"success\"\}}"
		string="${string%.*}"

		echo "[$timestring||-$(format_time $string)]"
		return 0
	else
		return 1
	fi
}

get_playlistpos() {
	local result=$(<<< '{ "command": ["get_property", "playlist-pos-1"] }' socat - "$MPV_SOCKET" 2>&1)
	if [[ "$result" =~ '"error":"success"' ]]; then
		local string="${result#\{\"data\":}"
		string="${string%,\"error\":\"success\"\}}"

		local posstring="$string"
	else
		return 1
	fi
	local result=$(<<< '{ "command": ["get_property", "playlist-count"] }' socat - "$MPV_SOCKET" 2>&1)
	if [[ "$result" =~ '"error":"success"' ]]; then
		string="${result#\{\"data\":}"
		string="${string%,\"error\":\"success\"\}}"

		echo "$posstring/$string"
		return 0
	else
		return 1
	fi
}

do_play_pause() {
	# '{ "command": ["cycle", "pause"] }' also works

	if [[ $(<<< '{ "command": ["get_property", "pause"] }' socat - "$MPV_SOCKET") =~ '"data":true' ]]; then
		local result=$(<<< '{ "command": ["set_property", "pause", false] }' socat - "$MPV_SOCKET" 2>&1)
		if [[ "$result" =~ '"error":"success"' ]]; then
			return 100
		else
			echo "$result"
			return 1
		fi
	else
		local result=$(<<< '{ "command": ["set_property", "pause", true] }' socat - "$MPV_SOCKET" 2>&1)
		if [[ "$result" =~ '"error":"success"' ]]; then
			return 101
		else
			echo "$result"
			return 1
		fi
	fi
}

do_stop() {
	local result=$(<<< '{ "command": ["quit"] }' socat - "$MPV_SOCKET" 2>&1)
	if [[ "$result" =~ '"error":"success"' ]]; then
		return 0
	else
		echo "$result"
		return 1
	fi
}

do_jump() {
	# $1: prev or next
	local result=$(<<< '{ "command": ["playlist_'$1'"] }' socat - "$MPV_SOCKET" 2>&1)
	if [[ "$result" =~ '"error":"success"' ]]; then
		return 0
	else
		echo "$result"
		return 1
	fi
}

notify() {
	notify-send -i "$1" "$(basename "$0") $action" "$2"
}

command -v socat &>/dev/null || {
	echo "socat not found, Exiting!"
	exit 1
}

action="$1"
case "$action" in
	play)
		if pkill -0 pianobar; then
			echo -n 'p' > "$PIANOBAR_FIFO"
			notify "gmusicbrowser" "▶▮▮"
		else
			result=$(do_play_pause); code=$?
			if [[ $code -eq 100 ]]; then
				notify "mpv" "▶  $(get_timestring) $(get_title)"
			elif [[ $code -eq 101 ]]; then
				notify "mpv" "▮▮  $(get_timestring) $(get_title)"
			else
				notify "mpv" "$result"
			fi
		fi;;
	stop)
		if pkill -0 pianobar; then
			echo -n 'q' > "$PIANOBAR_FIFO"
			notify "gmusicbrowser" "◼"
		else
			result=$(do_stop)
			if [[ $? -eq 0 ]]; then
				notify "mpv" "◼"
			else
				notify "mpv" "$result"
			fi
		fi;;
	prev|next)
		declare -A symbol
		symbol[prev]="⏮"; symbol[next]="⏭"

		if pkill -0 pianobar; then
			[[ $1 == "prev" ]] && exit

			echo -n 'n' > "$PIANOBAR_FIFO"
			notify "gmusicbrowser" "${symbol[$1]}"
		else
			oldtitle="$(get_title)"
			result=$(do_jump $1)
			if [[ $? -eq 0 ]]; then
				sleep 0.15
				playlistpos="$(get_playlistpos)"
				title="$(get_title)"

				if [[ "$title" && "$title" != "$oldtitle" ]]; then
					notify "mpv" "${symbol[$1]}  $title ($playlistpos)"
				else	# mpv is too slow
					notify "mpv" "${symbol[$1]}  ($playlistpos)" "$result"
				fi
			else
				notify "mpv" "$result"
			fi
		fi;;
esac
