#!/bin/sh
# Suspend to Idle
# parameter: --nolock

# Wakeup sources:
#	Power button for ~1s
#	Wake-on-LAN

# Enable Thinkpad keyboard wakeup source (FIXME: needs root)
# EDIT: nope, this also triggers on *closing* the lid switch!
##echo enabled >/sys/devices/platform/i8042/serio0/power/wakeup

# Disable USB wakeup sources to prevent random surprises (FIXME: needs root)
##for w in /sys/bus/usb/devices/*/power/wakeup; do
##	echo disabled >"$w"
##done

# also: https://news.ycombinator.com/item?id=28640190


# Switch off dGPU
##toggle-ivo off
##[[ $DEBUG ]] || xrandr --setprovideroutputsource nouveau 0x0

# Lock screen
[[ $1 == "--nolock" ]] || {
	xflock4 && sleep 1
}

# Blink suspend LED (FIXME: needs root)
# ex /etc/pm/sleep.d/95led
lsmod | grep -q ledtrig_timer | modprobe ledtrig_timer
for led in tpacpi::power tpacpi::unknown_led2; do	# power and lid leds
	echo "timer" >/sys/class/leds/$led/trigger
	echo "750" >/sys/class/leds/$led/delay_off
	echo "750" >/sys/class/leds/$led/delay_on
done

# Suspend
echo freeze | sudo tee /sys/power/state >/dev/null

# Restore LED
for led in tpacpi::power tpacpi::unknown_led2; do
	echo "none" >/sys/class/leds/$led/trigger
	echo "1" >/sys/class/leds/$led/brightness
done
