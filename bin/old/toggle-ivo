#!/bin/bash

on() {
	echo "Switching on..."
	notify-send -i xfce-display-extend "Intel Virtual Output" "** ON **\nstand by..."

	# sometimes (after boot after a system freeze when it was active?), starting i-v-o will do nothing and then freeze the system 30s later
	# curiously, running optirun works, so do this first to "prime" the GPU
	optirun ls &
	sleep 2

	intel-virtual-output
	xfce4-display-settings --minimal &
	sleep 1	# run a little longer to prevent chain-triggering by the Thinkpad
	if ! pgrep intel-virtual-o >/dev/null; then	# ivo tends to become unresponsive
		echo "Failed to start!"
		notify-send -i xfce-display-external "Intel Virtual Output" "failed to start! fuck."
	fi
}
off() {
	echo "Switching off..."
	notify-send -i xfce-display-internal "Intel Virtual Output" "** OFF **"
	killall intel-virtual-output
	sleep 1						# give ivo some time to clean up outputs (important!)
	if pgrep intel-virtual-o >/dev/null; then	# ivo tends to become unresponsive tho
		killall -9 intel-virtual-output
		sleep 1
	fi
	xrandr --auto	# shrink screen again - Xfwm4: moved windows are taken out of bounds by this
}

[[ $(pgrep -c "$(basename "$0")") -gt 1 ]] && exit 77 # previous instance still running, abort

# manual run
case $1 in
	on)	on; exit;;
	off)	off; exit;;
esac

# why the hell does pgrep truncate to 15 chars?? https://bugs.launchpad.net/ubuntu/+source/procps/+bug/295876
if pgrep intel-virtual-o >/dev/null; then
	off
else
	on
fi
