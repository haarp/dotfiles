#!/bin/bash

TERM=xterm-256color

ponysay "Welcome to Tgame!"; echo -ne "\n"

until [[ "$levels" =~ ^[0-9]+$ ]]; do
	read -p "How many levels would you like to play? " levels
done

# Color selection levels
for i in $(seq 1 $levels); do								# i=level index, j=color index (begin at 1)
	clear
	echo -ne "Level: $i\n\n"

	for j in $(seq 1 $[i*i] ); do
		[[ $[$j %14 ] == 0 ]] && echo -ne "\n\n"				# wrap every 14 colors
		color[j]=$[ RANDOM %231 ]						# random number between 0 and 231
		tput setab ${color[j]}; echo -n "  $j  "; tput sgr0; echo -n " "	# display number with colored bg
	done

	echo -ne "\n\n"
	until [[ "$answer" -gt 0 && "$answer" -le $[i*i] ]]; do
		read -p "Choose any color: " answer
	done

	selectedcolor[i]=${color[$answer]}						# selected color for each level
	unset answer
done



# Final level
pool=("${selectedcolor[@]}")								# copy array

clear
echo -ne "Final Level!\n\n"

for i in $(seq $[levels+1] $[levels*levels] ); do
	pool[i]=$[ RANDOM %231 ]							# add more random colors to the pool
done
pool=( $(echo "${pool[@]}" | sed -r 's/(.[^;]*;)/ \1 /g' | tr " " "\n" | shuf | tr -d " " ) )	# shuffle array
												# this array now begins at 0 !!

for j in $(seq 1 $[levels*levels] ); do
	[[ $[$j %14 ] == 0 ]] && echo -ne "\n\n"					# wrap every 14 colors
	tput setab ${pool[j-1]}; echo -n "  $j  "; tput sgr0; echo -n " "		# display number with colored bg
done

echo -ne "\n\nFind the colors in the order you selected them!\n\n"

# Results
for i in $(seq 1 $levels); do
	until [[ "$answer" -gt 0 && "$answer" -le $[levels*levels] ]]; do
		read -p "Color from level $i: " answer
	done

	if [[ "${pool[answer-1]}" == "${selectedcolor[i]}" ]]; then
		echo "Correct!"
	else
		echo "Wrong answer! You lose :P"
		echo "$i was correct."
		exit 1
	fi
	unset answer
done

echo "All answers were correct! A winrar is you!"
ponysay -o -f applebloom
exit 0
