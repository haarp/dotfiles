#!/bin/bash
# FIXME: doesn't work for firejail'ed windows (https://github.com/netblue30/firejail/discussions/5967)
# or tabbed because it sets no _NET_WM_PID

# https://superuser.com/a/784102
pidtree() (
	children=()
	while read p pp; do
		children[$pp]+=" $p"
	done <<< $(ps -e -o pid= -o ppid=)

	walk() {
		for i in ${children[$1]};do
			echo $i
			walk $i
		done
	}

	for i in "$@";do
		walk $i
	done
)

# gotta make this a process group killer
# or various xinputs would be left over afterwards
exit() {
##	kill -- -$$
	# fuck you, fuck this, i don't give a fuck anymore, just kill everything
	killall xprop xinput
	command exit "$@"
}


# allow keyboard cancel
# keyboard names may be duplicates :<
kbds=(); while read id; do
	id="${id#∼ }"	# remove weird shit from name of "floating" switched off devices
	xinput list --name-only "$id" | grep -qi 'keyboard' && kbds+=("$id")
done <<< $(xinput list --id-only)
for kbd in "${kbds[@]}"; do
	# we can't get xinput's pid in this pipe :<
	xinput test "$kbd" | while read line; do
		if [[ "$line" == "key release 9" ]]; then
			exit 1
		fi
	done &
done

pid=$(xprop _NET_WM_PID)
pid=${pid#_NET_WM_PID(CARDINAL) = }
[[ "$pid" ]] || exit 1
kill -0 $pid 2>/dev/null || {
	echo "PID \`$pid\` unusable!"
	exit 1
}

name="$(basename "$(readlink /proc/$pid/exe)")"

if grep -q ^State:$'\t'T /proc/$pid/status; then
	notify-send -i media-playback-start "${0##*/}" "Continuing $name"
	kill -CONT $pid $(pidtree $pid)
else
	notify-send -i media-playback-pause "${0##*/}" "Stopping $name"
	kill -STOP $pid $(pidtree $pid)
fi

exit 0
