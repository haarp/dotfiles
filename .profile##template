#!/bin/bash

# Fucking stop truncating the motherfucking history!
export HISTSIZE=-1
export HISTFILESIZE=$HISTSIZE

# Source user files if they exist
for _file in ~/.bashrcNOPE ~/.rbenvrc
do
	[[ -f "$_file" ]] && . "$_file"
done; unset _file

# Set XDG dirs if unset
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"

# Set PATH to include user dirs (bashrc also does it)
for _dir in ~/bin ~/.local/bin
do
	[[ -d "$_dir" ]] || continue
	[[ "$PATH" =~ ":$_dir" ]] && continue
	PATH="$_dir:$PATH"
done; unset _dir

# Create cache/temp dirs
# NOTE: some early starters (gnome-keyring) need ~/.cache earlier → handled by /etc/local.d
mkdir -p -m 700 "/tmp/cache-$USER" "$XDG_CONFIG_HOME/gvfs-metadata" "/tmp/.wine-$UID" "/tmp/.wine-$UID/temp"
# Wine temp
for _temp in \
	$HOME/.wine*/drive_c/windows/temp \
	$HOME/.wine*/drive_c/users/*/Temp \
	$HOME/.wine*/drive_c/users/*/Local\ Settings/Temporary\ Internet\ Files
do
	if [[ ! -L "$_temp" && -d "$_temp" ]]; then
		rm -rf "$_temp"
		ln -s /tmp/.wine-$UID/temp/ "$_temp"
	fi
done
# Fucking Electron garbage dumps its cache in the wrong place! (https://github.com/electron/electron/issues/8124)
# steal list from https://github.com/danisztls/ephemeral/blob/main/ephemeral
# FIXME: apps don't use the symlinks and even reset Dawn{Graphite,WebGPU}Cache, GPUCache on start :|
shopt -s extglob
for _app in \
	"$XDG_CONFIG_HOME/discord" \
	"$XDG_CONFIG_HOME/Signal" \
	"$XDG_CONFIG_HOME/SideQuest" \
	"$HOME/snap/slack/"!(current)"/.config/Slack"
do
	for _temp in \
		Cache \
		CachedData \
		CachedExtensions \
		"Code Cache" \
		DawnCache \
		DawnGraphiteCache \
		DawnWebGPUCache \
		GPUCache
	do
		if [[ ! -L "$_app/$_temp" && -d "$_app/$_temp" ]]; then
			mkdir -p -m 700 "$XDG_CONFIG_HOME/$(basename "$_app")/$_temp/"
			rm -rf "$_app/$_temp/"
			ln -s "$XDG_CONFIG_HOME/$(basename "$_app")/$_temp/" "$_app/$_temp"
		fi
	done
done
unset _app _temp

{% if yadm.class == "home" %}
if [[ $DISPLAY ]]; then
	# Video setup
	# FIXME: runs too late for xfce4-display-settings to pick up on login?
##	xrandr | awk '/connected/{print $1}' | while read display; do
