#!/bin/bash

## XDG locations
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"

## Make GUI applications use XDG paths
# also see https://github.com/b3nj5m1n/xdg-ninja
export ELECTRUMDIR="$XDG_DATA_HOME/electrum"
export GNUPGHOME="$XDG_DATA_HOME/gnupg"
export ICEAUTHORITY="$XDG_CACHE_HOME/ICEauthority"
export _JAVA_OPTIONS="-Duser.home=\"$XDG_DATA_HOME\""	# creates .java there, good enough
export RBENV_ROOT="$XDG_DATA_HOME/rbenv"
export RANDFILE="$XDG_CACHE_HOME/rnd"	# openssl
export XCOMPOSEFILE="$XDG_CONFIG_HOME/X11/XCompose"
# workaround https://gitlab.xfce.org/xfce/xfce4-settings/-/issues/490
export XCURSOR_PATH="$XDG_DATA_HOME/cursors:~/.cursors:$XDG_DATA_HOME/icons:~/.icons:\
/usr/local/share/cursors/xorg-x11:/usr/local/share/cursors:/usr/local/share/icons:/usr/local/share/pixmaps/xorg-x11:/usr/local/share/pixmaps:\
/usr/share/cursors/xorg-x11:/usr/share/cursors:/usr/share/icons:/usr/share/pixmaps/xorg-x11:/usr/share/pixmaps"


## Environment variables

# gtk3-nocsd setting (needs LD_PRELOAD), AND
# gtk3-classic settings (https://github.com/lah7/gtk3-classic/blob/master/README.Variables.md)
export GTK_CSD=0
###export GTK_BACKDROP=1
export GTK_USE_IEC_UNITS=1
export GTKM_INSERT_EMOJI=1
# Disable accessibility and GTK trying to contact non-existent accessibility bus and complaining about it (https://wiki.archlinux.org/title/Accessibility#Disable_accessibility)
export GTK_A11Y=none
export NO_AT_BRIDGE=1
# Switch GTK settings backend to text file instead of a fucking windoze registry
# can also use `memory` for volatile backend
# migration: `dconf dump / > ~/.config/glib-2.0/settings/keyfile`
###export GSETTINGS_BACKEND=keyfile

# Make QT apps not scale horribly (https://wiki.archlinux.org/title/HiDPI#Qt_5)
# also consider `QT_FONT_DPI=96` to override font DPI scaling
# KeePassXC: looks about right on 1.25; https://github.com/keepassxreboot/keepassxc/issues/2815
# OpenSCAD looks too big w/ 1.25, breaks w/ <1.0
# VirtualBox looks too big w/ 1.25, breaks w/ <1.0
export QT_ENABLE_HIGHDPI_SCALING=0
export QT_SCREEN_SCALE_FACTORS=1.0
# Make QT copy GTK's style (needs dev-qt/qtstyleplugins?) (https://wiki.archlinux.org/title/Uniform_look_for_Qt_and_GTK_applications#QGtk3Style)
export QT_QPA_PLATFORMTHEME=gtk3
# Make QT not scan Wifi all the fucking time (https://www.lesswrong.com/posts/8hxvfZiqH24oqyr6y/wireless-is-a-trap https://apple.stackexchange.com/a/312388)
export QT_BEARER_POLL_TIMEOUT=-1
# Make Nextcloud client STOP FUCKING LOGGING EVERY MOVED BIT (https://github.com/nextcloud/desktop/issues/5302#issuecomment-2139805467)
# it even motherfucking moves log archives from the log/ dir to the CONFIG DIR (on restart?) WHAT THE FUCK
# also chattr +i the fucking Nextcloud_sync.log, QT_LOGGING_RULES doesn't affect it
export QT_LOGGING_RULES='*=false'

# Java: Try to make GTK+ style work. Maybe.
export _JAVA_OPTIONS+=" -Dawt.useSystemAAFontSettings=on -Dswing.aatext=true -Dswing.defaultlaf=com.sun.java.swing.plaf.gtk.GTKLookAndFeel -Dswing.crossplatformlaf=com.sun.java.swing.plaf.gtk.GTKLookAndFeel"

# SSH: use my ssh-askpass, force it for consistency (see https://bugzilla.mindrot.org/show_bug.cgi?id=69)
export SSH_ASKPASS=ssh-askpass-wrapper
export SSH_ASKPASS_REQUIRE=force

# Firefox: Smooth scrolling
export MOZ_USE_XINPUT2=1
# Firefox: Fix stuck tooltips (https://bugzilla.mozilla.org/show_bug.cgi?id=1569439#c25)
export MOZ_GTK_TITLEBAR_DECORATION=system

# Chromium: don't scale horribly; source system-wide settings too
if [[ -d "/etc/chromium" ]]; then
	for f in /etc/chromium/*; do [[ -f "$f" ]] && source "$f"; done
	export CHROMIUM_USER_FLAGS="$CHROMIUM_FLAGS"
	CHROMIUM_USER_FLAGS+=" --force-device-scale-factor=1.33333"
fi

# Wine: disable winemenubuilder
export WINEDLLOVERRIDES=winemenubuilder.exe=d


## Set PATH to include user dirs (bashrc also does it)
for _dir in ~/bin ~/.local/bin
do
	[[ -d "$_dir" ]] || continue
	[[ "$PATH" =~ ":$_dir" ]] && continue
	PATH="$_dir:$PATH"
done; unset _dir


## LD_PRELOAD
_preload=(
	# Disable Cripple-AMD CPU dispatcher in Intel Math Kernel Library (https://danieldk.eu/Intel-MKL-on-AMD-Zen)
	# FIXME: breaks Steam game launch, unless given launch opts: `LD_PRELOAD="libpthread.so.0 libGL.so.1" %command%`
###	"$HOME/bogusintel.so"
	# gtk3-nocsd (also GTK_CSD env var)
###	"/usr/lib64/libgtk3-nocsd.so.0"
)
for _p in "${_preload[@]}"; do
	[[ -x "$_p" ]] || continue
	export LD_PRELOAD="$_p $LD_PRELOAD"
done; unset _preload _p


## Create cache/temp dirs
# NOTE: some early starters (gnome-keyring) need ~/.cache earlier → handled by /etc/local.d
( if [[ -L "$XDG_CACHE_HOME" ]]; then
	target="$(readlink "$XDG_CACHE_HOME")"
	mkdir -p -m 700 "$target"
fi )
# Wine temp
if command -v wine >/dev/null; then
	mkdir -p -m 700 "${TMPDIR:-/tmp}/.wine-$UID" "${TMPDIR:-/tmp}/.wine-$UID/temp"
	( for temp in \
		"$HOME"/.wine*/drive_c/windows/temp \
		"$HOME"/.wine*/drive_c/users/*/Temp \
		"$HOME"/.wine*/drive_c/users/*/Local\ Settings/Temporary\ Internet\ Files
	do
		if [[ ! -L "$temp" && -d "$temp" ]]; then
			rm -rf "$temp"
			ln -s "${TMPDIR:-/tmp}/.wine-$UID/temp/" "$temp"
		fi
	done )
fi
# Fucking Electron garbage dumps its cache in the wrong place! (https://github.com/electron/electron/issues/8124)
# steal list from https://github.com/danisztls/ephemeral/blob/main/ephemeral
# FIXME: apps don't use the symlinks and even reset Dawn{Graphite,WebGPU}Cache, GPUCache on start :|
shopt -s extglob
( for app in \
	"$XDG_CONFIG_HOME/discord" \
	"$XDG_CONFIG_HOME/Signal" \
	"$XDG_CONFIG_HOME/SideQuest" \
	"$HOME/snap/slack/"!(current)"/.config/Slack"
do
	for temp in \
		Cache \
		CachedData \
		CachedExtensions \
		"Code Cache" \
		DawnCache \
		DawnGraphiteCache \
		DawnWebGPUCache \
		GPUCache
	do
		if [[ ! -L "$app/$temp" && -d "$app/$temp" ]]; then
			mkdir -p -m 700 "$XDG_CACHE_HOME/${app##*/}/$temp/"
			rm -rf "$app/$temp/"
			ln -s "$XDG_CACHE_HOME/${app##*/}/$temp/" "$app/$temp"
		fi
	done
done )


{% if yadm.class == "home" %}
if [[ $DISPLAY ]]; then
	## Video setup
	# FIXME: runs too late for xfce4-display-settings to pick up on login?
	# Tearfree
###	xrandr | awk '/connected/{print $1}' | while read display; do
###		xrandr --output $display --set TearFree on
###	done
	# Monitor overclocking
	# amdgpu
###	custom_mode eDP 2560 1600 67.5 >/dev/null
###	custom_mode DisplayPort-1 3840 1600 82 >/dev/null
	# modesetting
###	custom_mode eDP-1 2560 1600 67.5 >/dev/null
###	custom_mode DP-2 3840 1600 82 >/dev/null
	# new thinkpad
	custom_mode eDP-1 1920 1080 82.5 >/dev/null
	custom_mode eDP-1 1920 1080 75 >/dev/null
	custom_mode DP-1 3840 1600 82 >/dev/null
	custom_mode DP-1 3840 1600 75 >/dev/null

	# Nvidia video setup
	# Underclock to save power when Nvidia goes to higher P-states (which is all the fucking time)
	# NOTE: Core below -515 (15MHz bins) will lock GPU into highest P-state
	# NOTE: Memory can't go below that of second-highest P-state, attempts will lock out the highest P-state
	# NOTE: to edit specific P-states: [gpu:0]/GPUGraphicsClockOffset[$level]=$offset, [gpu:0]/GPUMemoryTransferRateOffset[$level]=$offset
	###nvidia-settings \
	###	-a [gpu:0]/GPUGraphicsClockOffsetAllPerformanceLevels=-500 \
	###	-a [gpu:0]/GPUMemoryTransferRateOffsetAllPerformanceLevels=-199 \
	###	2>/dev/null &
	# Enable ForceCompositionPipeline to prevent tearing, disable Flipping to recover some input lag due to that
	# EDIT: nope, prevents GPU from dropping to lowest P-state
	###nvidia-settings --assign CurrentMetaMode="nvidia-auto-select +0+0 { ForceCompositionPipeline = On }" --assign AllowFlipping=0 &
fi
{% endif %}

{% if yadm.class == "home" %}
## Input setup
xinput map-to-output "ELAN Touchscreen" eDP-1
{% endif %}


