{% if yadm.class == "home" %}
[general]
{% endif %}
import = [
	# custom theme
#	"~/.config/alacritty/alacritty-theme.git/themes/oxocarbon.toml",
  # cool themes:
  # blood_moon, hyper: very saturated, good contrasts
  # breeze: very good contrast, mostly accurate colors
  # campbell: very good contrast EXCEPT dark blue, accurate colors
  # chicago95: muted text, contrasty colors
  # citylights: contrasty
  # Cobalt2: pleasant blue hue, contrasty colors
  # dracula_plus: it's ok
  # enfocado_dark: ok, low brightness
  # gnome_terminal: bluish hue, good contrast
  # iterm, kitty: good contrasts, accurate colors
  # midnight_haze: low contrast but pleasant pastel color choices
  # monokai_charcoal: very very nice contrasts, high saturation
  # omni: purple/pink focus, insanely bright green
  # oxocarbon: pink focus, nice looking, mediocre contrast
  # vesper: pink focus, ok-ish contrast
  # pastel_dark: bad color contrast, nice text contrast
  # pencil_dark: pleasant colors, mediocre color contrast
  # seashells: impressive colors, blue focus, bad color contrast
  # terminal_app, xterm: generic high-contrast
  # ubuntu: not terrible, red hue
  # vscode: decent enough, good color contrast
  # wombat: saturated, excellent contrasts!
  # zenburn: pleasant low brightness, bad contrast
  # favs:
  # Cobalt2, oxocarbon, monokai_charcoal
]

[env]
TERM = "xterm-256color"

[window]
# FIXME: no effect in `tabbed`
dimensions.columns = 119
dimensions.lines = 35
padding.x = 1
padding.y = 1
opacity = 0.97

[scrolling]
history = 100000
multiplier = 8

[font]
normal.family = "Terminus"
{% if yadm.class == "home" %}
size = 6.5
{% endif %}
{% if yadm.class == "work" %}
size = 10.0
{% endif %}

[colors]
draw_bold_text_with_bright_colors = true
# My classic term colors
# Termux color mappings in comments
[colors.primary]
foreground = "#d8d8d8"			#foreground i.e. default text
background = "#181818"			#background i.e. default bg
bright_foreground = "#eeeeec"	#color15 i.e. default bright text (\e[1m)
[colors.cursor]
cursor = "#ee00ee"	#cursor
[colors.normal]
black = "#2e3436" 	#color0
red = "#cc0000"		#color1
green = "#4e9a06"	#color2
yellow = "#b39000"	#color3
blue = "#3465a4"	#color4
magenta = "#75507b"	#color5
cyan = "#06989a"	#color6
white = "#d3d7cf"	#color7
[colors.bright]
black = "#555853"	#color8
red = "#ef5c5c"		#color9
green = "#8ae234"	#color10
yellow = "#fce94f"	#color11
blue = "#729fcf"	#color12
magenta = "#ad7fa8"	#color13
cyan = "#34e2e2"	#color14
white = "#eeeeec"	#color15

[bell]
animation = "Ease"
duration = 75

[selection]
semantic_escape_chars = ",│`|:\"' ()[]{}<>\t‘’/?;_-=#%&^"

[[hints.enabled]]
regex = "(ipfs:|ipns:|magnet:|mailto:|gemini://|gopher://|https://|http://|news:|file:|git://|ssh:|ftp://)[^\u0000-\u001F\u007F-\u009F<>\"\\s{-}\\^⟨⟩`\\\\]+"
hyperlinks = true
post_processing = true
command = "xdg-open"
mouse.enabled = true
mouse.mods = "Alt"

[keyboard]
bindings = [
	# Clipboard
	{ key = "C", mods = "Control|Shift", action = "Copy" },
	{ key = "X", mods = "Control", action = "Copy" },
	# Traditional Ctrl-x
	{ key = "X", mods = "Control|Alt", chars = "\u0018" },
	{ key = "V", mods = "Control", action = "Paste" },
	# Primary selection
	# don't use just Insert as mc uses that for select
	{ key = "Insert", mods = "Shift", action = "PasteSelection" },
	# Search
	{ key = "Slash", mods = "Control", action = "SearchForward" },
	{ key = "N", mods = "Control", action = "SearchFocusNext" },
	{ key = "N", mods = "Control|Shift", action = "SearchFocusPrevious" },
	# Misc
	{ key = "W", mods = "Control", action = "Quit" },
	# sigkill processes :D (https://github.com/alacritty/alacritty/issues/3711 -> use log filename to get pid)
	{ key = "C", mods = "Control|Alt", command = { program = "bash", args = ["-c", "shpid=$(pgrep -P ${ALACRITTY_LOG//[^0-9]/}) && pkill -9 -P $shpid"] } },
	# Open new instance in same dir
	{ key = "Return", mods = "Control|Shift", action = "SpawnNewInstance" },
	# Open file browser
	{ key = "F5", mods = "Alt", command = { program = "xdg-open", args = ["."] } },
	# Focus prompt (https://github.com/alacritty/alacritty/issues/5850#issuecomment-2342001833)
	{ key = "Escape", action = "ToggleViMode", mode="Vi" },
	{ key = "PageUp", mods = "Control", action = "ToggleViMode", mode = "~Search|~Vi" },
	{ key = "PageUp", mods = "Control", action = "SearchBackward", mode = "~Search|~Vi" },
	{ key = "PageUp", mods = "Control", chars = "", mode = "~Search|~Vi" },
	{ key = "PageUp", mods = "Control", action = "SearchConfirm", mode = "~Search|~Vi" },
	{ key = "PageUp", mods = "Control", action = "SearchBackward", mode = "Vi" },
	{ key = "PageUp", mods = "Control", chars = "", mode = "Vi" },
	{ key = "PageUp", mods = "Control", action = "SearchConfirm", mode = "Vi" },
	# somehow broken
	{ key = "PageDown", mods = "Control", action = "ToggleViMode", mode = "~Search|~Vi" },
	{ key = "PageDown", mods = "Control", action = "SearchForward", mode = "~Search|~Vi" },
	{ key = "PageDown", mods = "Control", chars = "", mode = "~Search|~Vi" },
	{ key = "PageDown", mods = "Control", action = "SearchConfirm", mode = "~Search|~Vi" },
	{ key = "PageDown", mods = "Control", action = "SearchForward", mode = "Vi" },
	{ key = "PageDown", mods = "Control", chars = "", mode = "Vi" },
	{ key = "PageDown", mods = "Control", action = "SearchConfirm", mode = "Vi" },
]

