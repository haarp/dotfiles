<?xml version="1.0" encoding="UTF-8"?>
<actions>
<action>
	<icon>utilities-terminal</icon>
	<name>Open Terminal here</name>
	<submenu></submenu>
	<unique-id>1459188327224642-8</unique-id>
	<command>exo-open --launch TerminalEmulator --working-directory %f</command>
	<description>Open in Terminal</description>
	<range></range>
	<patterns>*</patterns>
	<directories/>
</action>
<action>
	<icon>media-playback-start-symbolic</icon>
	<name>Execute</name>
	<submenu></submenu>
	<unique-id>1524821177262629-5</unique-id>
	<command>if [[ -x %f ]]; then %f; else zenity --error --text=&quot;File not executable!&quot;; fi</command>
	<description>Run the script or executable</description>
	<range></range>
	<patterns>*</patterns>
	<other-files/>
</action>
<action>
	<icon>insert-link</icon>
	<name>Symlink</name>
	<submenu></submenu>
	<unique-id>1692284017675730-1</unique-id>
	<command>for f in %F; do ln -s &quot;$f&quot; &quot;$f (link)&quot;; done</command>
	<description>Create symlink(s) in same dir</description>
	<range>*</range>
	<patterns>*</patterns>
	<directories/>
	<audio-files/>
	<image-files/>
	<other-files/>
	<text-files/>
	<video-files/>
</action>
<action>
	<icon>edit-copy</icon>
	<name>Duplicate</name>
	<submenu></submenu>
	<unique-id>1593073193565417-1</unique-id>
	<command>for f in %F; do cp -a --reflink=auto -- &quot;$f&quot; &quot;$f (copy)&quot;; done</command>
	<description>Duplicate item(s)</description>
	<range></range>
	<patterns>*</patterns>
	<directories/>
	<audio-files/>
	<image-files/>
	<other-files/>
	<text-files/>
	<video-files/>
</action>
<action>
	<icon>edit-cut</icon>
	<name>Shred</name>
	<submenu></submenu>
	<unique-id>1524821199300299-6</unique-id>
	<command>zenity --question --text=&quot;Are you sure that you want to permanently shred these files?\n\n%N&quot; --ok-label Shred --cancel-label Cancel &amp;&amp; shred -fuz -- %F</command>
	<description>Shred files</description>
	<range></range>
	<patterns>*</patterns>
	<audio-files/>
	<image-files/>
	<other-files/>
	<text-files/>
	<video-files/>
</action>
<action>
	<icon>mate-disk-usage-analyzer</icon>
	<name>Disk usage</name>
	<submenu></submenu>
	<unique-id>1463326878489308-1</unique-id>
	<command>mate-disk-usage-analyzer %f</command>
	<description>View the disk usage with mate-disk-usage-analyzer</description>
	<range></range>
	<patterns>*</patterns>
	<directories/>
</action>
<action>
	<icon>list-add</icon>
	<name>Checksums</name>
	<submenu></submenu>
	<unique-id>1524821492949567-7</unique-id>
	<command>zenity --info --text=&quot;$(cd %d; for f in %N; do md5sum --tag -- &quot;$f&quot;; sha1sum --tag -- &quot;$f&quot;; sha256sum --tag -- &quot;$f&quot;; echo -ne &quot;\n&quot;; done)&quot; --ellipsize</command>
	<description>Compute various checksums</description>
	<range></range>
	<patterns>*</patterns>
	<audio-files/>
	<image-files/>
	<other-files/>
	<text-files/>
	<video-files/>
</action>
<action>
	<icon>accessories-text-editor</icon>
	<name>Open in Text Editor</name>
	<submenu></submenu>
	<unique-id>1502450948269367-1</unique-id>
	<command>xed %F</command>
	<description>Open with xed</description>
	<range></range>
	<patterns>*</patterns>
	<audio-files/>
	<image-files/>
	<other-files/>
	<text-files/>
	<video-files/>
</action>
<action>
	<icon>ghex</icon>
	<name>Open in Hex Editor</name>
	<submenu></submenu>
	<unique-id>1367862950768375-6</unique-id>
	<command>qhexedit %F</command>
	<description>Open with QHexEdit2</description>
	<range></range>
	<patterns>*</patterns>
	<audio-files/>
	<image-files/>
	<other-files/>
	<text-files/>
	<video-files/>
</action>
<action>
	<icon>io.github.mightycreak.Diffuse</icon>
	<name>Compare</name>
	<submenu></submenu>
	<unique-id>1463326930914351-2</unique-id>
	<command>diffuse %F</command>
	<description>Compare with Diffuse</description>
	<range></range>
	<patterns>*</patterns>
	<other-files/>
	<text-files/>
</action>
<action>
	<icon>viewnior</icon>
	<name>Open in Viewnior</name>
	<submenu></submenu>
	<unique-id>1595231901084183-1</unique-id>
	<command>viewnior %F</command>
	<description>Open with Viewnior (no recursion)</description>
	<range></range>
	<patterns>*</patterns>
	<directories/>
	<image-files/>
</action>
<action>
	<icon>mpv</icon>
	<name>Open in mpv</name>
	<submenu></submenu>
	<unique-id>1524820963020693-3</unique-id>
	<command>mpv --no-terminal --force-window=immediate -- %F</command>
	<description>Open with mpv</description>
	<range></range>
	<patterns>*</patterns>
	<directories/>
	<audio-files/>
	<video-files/>
</action>
<action>
	<icon>xfce4-clipman-plugin</icon>
	<name>Copy contents to clipboard</name>
	<submenu></submenu>
	<unique-id>1482516704507442-4</unique-id>
	<command>cat -- %F | head -c -1 | xclip -i -selection clipboard</command>
	<description>Copy the conents of a text file to the clipboard</description>
	<range></range>
	<patterns>*</patterns>
	<other-files/>
	<text-files/>
</action>
<action>
	<icon>insert-text</icon>
	<name>Download clipboard URL here</name>
	<submenu></submenu>
	<unique-id>1472803200891713-1</unique-id>
	<command>wget -q --content-disposition --no-clobber -P %f -- &quot;$(xclip -o -selection clipboard)&quot;</command>
	<description>Download the current clipboard URL into the directory</description>
	<range></range>
	<patterns>*</patterns>
	<directories/>
</action>
<action>
	<icon>image-x-generic</icon>
	<name>Prepare pic for sharing</name>
	<submenu></submenu>
	<unique-id>1603022702075128-1</unique-id>
	<command>size=$(zenity --scale --text=&quot;Size (%%)&quot; --value=50) &amp;&amp; quality=$(zenity --scale --text=Quality --value=75) &amp;&amp; for f in %F; do convert &quot;$f&quot; -resize ${size}%% -quality $quality -strip &quot;$HOME/Downloads/Share/$(basename &quot;$f&quot;)&quot;; done &amp;&amp; dbus-send --type=method_call --dest=org.xfce.Thunar /org/xfce/FileManager org.xfce.FileManager.DisplayFolderAndSelect string:&quot;$HOME/Downloads/Share/&quot; string:&quot;$(basename &apos;%f&apos;)&quot; string:&quot;&quot; string:&quot;&quot;</command>
	<description>Resize, recompress, strip metadata and put picture in /tmp</description>
	<range></range>
	<patterns>*</patterns>
	<image-files/>
</action>
<action>
	<icon>insert-image</icon>
	<name>Upload to Imgur</name>
	<submenu></submenu>
	<unique-id>1482516723824333-5</unique-id>
	<command>imgurbash2 %F</command>
	<description>Upload image to Imgur</description>
	<range></range>
	<patterns>*</patterns>
	<image-files/>
	<video-files/>
</action>
<action>
	<icon>archive-manager</icon>
	<name>Mount archive</name>
	<submenu></submenu>
	<unique-id>1645981276894311-1</unique-id>
	<command>/usr/libexec/gvfsd-archive file=%f # also see gio mount</command>
	<description>Mount archive using GVfs</description>
	<range></range>
	<patterns>*.zip;*.rar;*.7z;*.tar.*</patterns>
	<other-files/>
</action>
</actions>
