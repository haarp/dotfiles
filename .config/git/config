[init]
	defaultBranch = master

[user]
	name = haarp
	email = main.haarp@gmail.com
[credential]
	helper = cache
[push]
	default = current
	followTags = true
[core]
	compression = 9
	# parallelization
	preloadindex = true

[color]
	ui = true
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green
[color "diff"]
	meta = yellow
[color "status"]
	added = yellow
	changed = green
	untracked = cyan

# make diffs a bit more semantic (https://news.ycombinator.com/item?id=11057421)
#[diff]
#	algorithm = patience

# infra-line color highlighting (https://github.com/git/git/blob/master/contrib/diff-highlight/README)
[pager]
	log = "if which diff-highlight >/dev/null; then df=diff-highlight; else df=cat; fi; $df | less"
	show = "if which diff-highlight >/dev/null; then df=diff-highlight; else df=cat; fi; $df | less"
	diff = "if which diff-highlight >/dev/null; then df=diff-highlight; else df=cat; fi; $df | less"
[interactive]
	diffFilter = "if which diff-highlight >/dev/null; then df=diff-highlight; else df=cat; fi; $df"

# rebase by default
[pull]
	rebase = true

[alias]
	# get lists
	branches = branch -a
	remotes = remote -v
	stashes = stash list
	tags = tag

	# undo shit
	unstage = reset -q HEAD --
	discard = checkout --
	uncommit = reset --mixed HEAD~
	amend = commit --amend
	unstash = stash pop
	nuke = !git reset --hard HEAD && git clean -d -f

	# misc
	graph = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset'
	precommit = diff --cached --diff-algorithm=minimal -w

	# search commits for changes with searchstring
	search = log -G

	# same-line diff outputs
	wdiff = diff --color-words
	wshow = show --color-words

	# https://stackoverflow.com/a/11768843/5424487
	# e.g.	git change-commits GIT_AUTHOR_NAME "old name" "new name"
	#	git change-commits GIT_AUTHOR_EMAIL "old@email.com" "new@email.com" [-f] HEAD~10..HEAD
	#	                   GIT_COMMITTER_EMAIL
	# also see https://stackoverflow.com/a/750182/5424487
	change-commits = "!f() { VAR=$1; OLD=$2; NEW=$3; shift 3; git filter-branch --env-filter \"if [[ \\\"$`echo $VAR`\\\" = '$OLD' ]]; then export $VAR='$NEW'; fi\" $@; }; f "

