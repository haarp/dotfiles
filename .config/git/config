## YADM stuff

# sub repos
# git will automatically turn added repos into submodules if .git is present
# submodules only store an url and commit reference, no local changes >:(
# -> submodules suck
# subtree will add a repo, but nuke our checked-out .git
# -> fuck you, subtrees
# -> rename .git, add, rename .git back
[alias]
addrepo = !sh -c 'mv "$1/.git" "$1/.git-nope" && git add -- "$1" ":!$1/.git-nope" && mv "$1/.git-nope" "$1/.git"' -

