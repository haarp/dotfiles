# dun care about copyright
startup_message off

# make fullscreen applications not remain in scrollback buffer after exit
altscreen on

# scrollback x1000
defscrollback 100000

# keep finished screens alive
zombie qr

# status line
hardstatus alwayslastline
hardstatus string '%{= kg}[%{G}%H%? %1`%?%{g}][%= %{= kw}%-w%{+b yk} %n:%t%?(%u)%? %{-}%+w %=%{g}][%{B}%S%{g}]'
