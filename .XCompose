<Multi_key> <asterisk> <I>					: "Ι"	# GREEK CAPITAL LETTER ΙΟΤΑ
<Multi_key> <asterisk> <J>					: "Ξ"	# GREEK CAPITAL LETTER XI
<Multi_key> <asterisk> <K>					: "Κ"	# GREEK CAPITAL LETTER KAPPA
<Multi_key> <asterisk> <L>					: "Λ"	# GREEK CAPITAL LETTER LAMBDA
