# Subscript
<Multi_key> <underscore> <0>			: "₀"
<Multi_key> <underscore> <1>			: "₁"
<Multi_key> <underscore> <2>			: "₂"
<Multi_key> <underscore> <3>			: "₃"
<Multi_key> <underscore> <4>			: "₄"
<Multi_key> <underscore> <5>			: "₅"
