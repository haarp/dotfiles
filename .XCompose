<Multi_key> <underscore> <8>			: "₈"
<Multi_key> <underscore> <9>			: "₉"
<Multi_key> <underscore> <plus>			: "₊"
<Multi_key> <underscore> <minus>		: "₋"
<Multi_key> <underscore> <equal>		: "₌"
<Multi_key> <underscore> <parenleft>	: "₍"
<Multi_key> <underscore> <parenright>	: "₎"
<Multi_key> <underscore> <a>			: "ₐ"
<Multi_key> <underscore> <e>			: "ₑ"
<Multi_key> <underscore> <h>			: "ₕ"
<Multi_key> <underscore> <i>			: "ᵢ"
<Multi_key> <underscore> <j>			: "ⱼ"
<Multi_key> <underscore> <k>			: "ₖ"
<Multi_key> <underscore> <l>			: "ₗ"
<Multi_key> <underscore> <m>			: "ₘ"
<Multi_key> <underscore> <n>			: "ₙ"
<Multi_key> <underscore> <o>			: "ₒ"
<Multi_key> <underscore> <p>			: "ₚ"
<Multi_key> <underscore> <r>			: "ᵣ"
<Multi_key> <underscore> <s>			: "ₛ"
<Multi_key> <underscore> <t>			: "ₜ"
<Multi_key> <underscore> <u>			: "ᵤ"
<Multi_key> <underscore> <v>			: "ᵥ"
<Multi_key> <underscore> <x>			: "ₓ"

# Greek letters (same as Emacs)
<Multi_key> <asterisk> <a>					: "α"	# GREEK SMALL LETTER ALPHA
<Multi_key> <asterisk> <b>					: "β"	# GREEK SMALL LETTER BETA
<Multi_key> <asciicircum> <asterisk> <b>	: "ᵝ"
<Multi_key> <underscore> <asterisk> <b>		: "ᵦ"
<Multi_key> <asterisk> <c>					: "ψ"	# GREEK SMALL LETTER PSI
<Multi_key> <asterisk> <d>					: "δ"	# GREEK SMALL LETTER DELTA
<Multi_key> <asciicircum> <asterisk> <d>	: "ᵟ"
<Multi_key> <asterisk> <e>					: "ε"	# GREEK SMALL LETTER EPSILON
<Multi_key> <asterisk> <f>					: "φ"	# GREEK SMALL LETTER PHI
<Multi_key> <asciicircum> <asterisk> <f>	: "ᵠ"
<Multi_key> <underscore> <asterisk> <f>		: "ᵩ"
<Multi_key> <asterisk> <g>					: "γ"	# GREEK SMALL LETTER GAMMA
<Multi_key> <asciicircum> <asterisk> <g>	: "ᵞ"
<Multi_key> <underscore> <asterisk> <g>		: "ᵧ"
<Multi_key> <asterisk> <h>					: "η"	# GREEK SMALL LETTER ΕΤΑ
<Multi_key> <e> <f> <f>						: "η"	# GREEK SMALL LETTER ΕΤΑ
<Multi_key> <asterisk> <i>					: "ι"	# GREEK SMALL LETTER ΙΟΤΑ
<Multi_key> <asterisk> <j>					: "ξ"	# GREEK SMALL LETTER XI
<Multi_key> <asterisk> <k>					: "κ"	# GREEK SMALL LETTER KAPPA
<Multi_key> <asterisk> <l>					: "λ"	# GREEK SMALL LETTER LAMBDA
<Multi_key> <asterisk> <m>					: "μ"	# GREEK SMALL LETTER MU
<Multi_key> <m> <u>							: "μ"	# GREEK SMALL LETTER MU
<Multi_key> <asterisk> <n>					: "ν"	# GREEK SMALL LETTER NU
<Multi_key> <asterisk> <o>					: "ο"	# GREEK SMALL LETTER OMICRON
<Multi_key> <asterisk> <p>					: "π"	# GREEK SMALL LETTER PI
<Multi_key> <p> <i>							: "π"	# GREEK SMALL LETTER PI
<Multi_key> <asterisk> <r>					: "ρ"	# GREEK SMALL LETTER RHO
<Multi_key> <underscore> <asterisk> <r>		: "ᵨ"
<Multi_key> <asterisk> <s>					: "σ"	# GREEK SMALL LETTER SIGMA
<Multi_key> <asterisk> <t>					: "τ"	# GREEK SMALL LETTER TAU
<Multi_key> <asterisk> <u>					: "θ"	# GREEK SMALL LETTER THETA
