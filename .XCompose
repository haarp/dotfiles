<Multi_key> <asterisk> <w>					: "ς"	# GREEK SMALL LETTER FINAL SIGMA
<Multi_key> <asterisk> <x>					: "χ"	# GREEK SMALL LETTER CHI
<Multi_key> <asciicircum> <asterisk> <x>	: "ᵡ"
<Multi_key> <underscore> <asterisk> <x>		: "ᵪ"
<Multi_key> <asterisk> <y>					: "υ"	# GREEK SMALL LETTER UPSILON
<Multi_key> <asterisk> <z>					: "ζ"	# GREEK SMALL LETTER ZETA
