# Arrows
<Multi_key> <less> <minus>			: "←"
<Multi_key> <minus> <greater>		: "→"
<Multi_key> <bar> <asciicircum>		: "↑"
<Multi_key> <asciicircum> <bar>		: "↑"
<Multi_key> <u> <o>					: "↑"
<Multi_key> <bar> <v>				: "↓"
<Multi_key> <v> <bar>				: "↓"
<Multi_key> <d> <n>				: "↓"
###<Multi_key> <less> <minus> <greater>		: "↔"	# breaks leftwards arrow

# Math
<Multi_key> <0> <0>					: "∞"
<Multi_key> <i> <n> <f>				: "∞"
<Multi_key> <minus> <plus> 			: "∓"	# replaces plusminus on this
<Multi_key> <exclam> <equal>		: "≠"
<Multi_key> <asciitilde> <equal>	: "≈"
<Multi_key> <equal> <asciitilde>	: "≈"
<Multi_key> <asciicircum> <equal>	: "≘"
<Multi_key> <equal> <asciicircum>	: "≘"
<Multi_key> <question> <equal>		: "≟"
<Multi_key> <equal> <question>		: "≟"
<Multi_key> <less> <equal>			: "≤"
<Multi_key> <greater> <equal>		: "≥"
<Multi_key> <parenleft> <E>			: "∈"
<Multi_key> <E> <parenleft>			: "∈"
<Multi_key> <s> <u> <m>				: "∑"
<Multi_key> <i> <n> <t>				: "∫"
<Multi_key> <bar> <C>				: "ℂ"	# complex numbers
<Multi_key> <bar> <N>				: "ℕ"	# natural numbers
<Multi_key> <bar> <Q>				: "ℚ"	# rational numbers
<Multi_key> <bar> <R>				: "ℝ"	# real numbers
<Multi_key> <bar> <Z>				: "ℤ"	# integers

# Bitcoin
<Multi_key> <b> <t> <c>				: "₿"
<Multi_key> <x> <b> <t>				: "₿"
<Multi_key> <B> <bar>				: "₿"
<Multi_key> <bar> <B>				: "₿"

# Misc
<Multi_key> <i> <n> <v> <i> <s>		: "​"	# Zero-width space

# Symbols
<Multi_key> <slash> <exclam> <backslash>	: "⚠"
<Multi_key> <o> <x>					: "☠"
<Multi_key> <a> <t> <o> <m>			: "⚛"
<Multi_key> <r> <a> <d>				: "☢"
<Multi_key> <b> <i> <o>				: "☣"
<Multi_key> <h> <v>					: "⚡"
<Multi_key> <c> <c> <c> <p>			: "☭"
<Multi_key> <6> <6> <6>				: "⛧"
<Multi_key> <o> <minus> <plus>		: "♀"
<Multi_key> <o> <t>					: "♀"
<Multi_key> <o> <minus> <greater>	: "♂"
<Multi_key> <n> <o> <t> <e>			: "♪"
<Multi_key> <c> <h> <e> <c> <k>		: "✓"	# ☑
<Multi_key> <exclam> <c> <h> <e> <c>		: "☐"
<Multi_key> <question> <i>			: "⸮"	# irony
<Multi_key> <i> <question>			: "⸮"

# Emoji
<Multi_key> <semicolon> <parenright>		: "😉"
<Multi_key> <colon> <D>						: "😃"
<Multi_key> <o> <colon> <parenright>		: "😇"
<Multi_key> <bar> <colon> <parenright>		: "😇"
<Multi_key> <greater> <colon> <parenright>	: "😈"
