## Hints:
# - the first obtained value for each parameter is used
# - to generate a keypair: ssh-keygen -t rsa -b 4096
# - to change key passphrase: ssh-keygen -p -f $filename
# - to see the config that would be used: ssh -G foo | sort
# - when using RemoteCommand for interactive shells, also add 'RequestTTY yes' (starting with OpenSSH 7.6) - or patch openssh...

Include ~/.ssh/config.local

# No. https://security.stackexchange.com/a/56283
HashKnownHosts no

# Stop asking multiple times when I want to cancel! Can't Ctrl+c graphical ssh-askpass
NumberOfPasswordPrompts 1

# Add keys to ssh-agent automatically
# and request confirmation on each use (consider agent forwarding)
# https://web.archive.org/web/20190412143908/https://github.com/matrix-org/matrix.org/issues/357
#AddKeysToAgent confirm

# Timeout after 60 seconds (ServerAliveCount defaults to 3) and time out connects sooner
ServerAliveInterval 20
ConnectTimeout 30

# Send env
# BUG: Debian/Ubuntu override LANG, LANGUAGE by default via /etc/default/locale!
# https://bugs.launchpad.net/ubuntu/+source/openssh/+bug/920749
# https://bugs.debian.org/cgi-bin/bugreport.cgi?bug=313317
# https://bugzilla.mindrot.org/show_bug.cgi?id=1346
SendEnv LANG LANGUAGE LC_* TZ COLORTERM NO_COLOR

# Connection Multiplexing
#ControlMaster auto
#ControlPath /run/user/%i/ssh/socket-%C

# Security (Source: https://stribika.github.io/2015/01/04/secure-secure-shell.html)
KexAlgorithms curve25519-sha256@libssh.org,diffie-hellman-group-exchange-sha256
Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com,aes256-ctr,aes192-ctr,aes128-ctr
MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com,umac-128-etm@openssh.com,hmac-sha2-512,hmac-sha2-256,umac-128@openssh.com

UserKnownHostsFile ~/.ssh/known_hosts.d/general

# Don't add RFC1918 IPs to known_hosts
# the default as of OpenSSH 8.5
Match exec "[[ $(getent ahostsv4 %h) =~ ^(192\.168\.|10\.|172\.1[6789]\.|172\.2[0-9]\.|172\.3[01]\.) ]]"
	CheckHostIP no
